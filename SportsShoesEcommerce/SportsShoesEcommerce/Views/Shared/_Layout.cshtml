@using Microsoft.AspNetCore.Identity
@using SportsShoesEcommerce.Models
@using SportsShoesEcommerce.Data
@using Microsoft.EntityFrameworkCore

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext DbContext

@{
    ApplicationUser currentUser = null;
    if (SignInManager.IsSignedIn(User))
    {
        currentUser = await UserManager.GetUserAsync(User);
    }

    var categories = await DbContext.Categories.Where(c => c.IsDeleted == false).ToListAsync();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NextStep</title>

    <link rel="stylesheet" href="~/user/css/vendor.css">
    <link rel="stylesheet" type="text/css" href="~/user/css/style.css">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,900;1,900&family=Source+Sans+Pro:wght@400;600;700;900&display=swap" rel="stylesheet">

    <style>
        :root {
            /* NextStep Teal */
            --brand-teal: #00C2CB;
        }

        .text-hover-brand:hover {
            color: var(--brand-teal) !important;
            transition: color 0.2s ease-in-out;
        }

        .pfp-chevron {
            font-size: 0.70rem;
            margin-top: 2px;
            transition: transform 0.2s;
        }

        .dropdown:hover .pfp-chevron {
            transform: rotate(180deg);
            color: var(--brand-teal) !important;
        }
    </style>
</head>
<body>

    <svg xmlns="http://www.w3.org/2000/svg" style="display: none;">
        <symbol xmlns="http://www.w3.org/2000/svg" id="close" viewBox="0 0 16 16">
            <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z" />
        </symbol>
        <symbol xmlns="http://www.w3.org/2000/svg" id="search" viewBox="0 0 24 24">
            <path fill="currentColor" d="M10 18a7.952 7.952 0 0 0 4.897-1.688l4.396 4.396l1.414-1.414l-4.396-4.396A7.952 7.952 0 0 0 18 10c0-4.411-3.589-8-8-8s-8 3.589-8 8s3.589 8 8 8zm0-14c3.309 0 6 2.691 6 6s-2.691 6-6 6s-6-2.691-6-6s2.691-6 6-6z" />
        </symbol>
    </svg>

    <div class="search-box bg-dark position-relative">
        <div class="search-wrap">
            <div class="close-button">
                <svg class="close" style="fill: white; width: 24px; height: 24px; cursor: pointer;">
                    <use xlink:href="#close"></use>
                </svg>
            </div>
            <form id="active-search-form" class="text-center pt-3" asp-controller="Search" asp-action="Index" method="get">
                <input type="text" name="q" class="search-input" style="color: #fff !important; background-color: transparent !important; border-bottom: 2px solid #fff;" placeholder="Search shoes, brands, or categories..." autocomplete="off" autofocus>
                <button type="submit" class="border-0 bg-transparent" style="cursor: pointer;">
                    <svg class="search" style="fill: white; width: 24px; height: 24px;">
                        <use xlink:href="#search"></use>
                    </svg>
                </button>
            </form>
        </div>
    </div>

    <header id="header" class="site-header text-black">

        <div class="header-top bg-dark text-white py-1">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-md-4 d-none d-md-block">
                    </div>
                    <div class="col-md-4 col-sm-12 text-center">
                        <p class="m-0 small fw-bold text-uppercase" style="letter-spacing: 1px; font-size: 0.8rem;">
                            Free Shipping on orders over $100
                        </p>
                    </div>
                    <div class="col-md-4 d-none d-md-block text-end">
                        <div class="d-flex justify-content-end gap-3 fw-bold" style="font-size: 0.8rem;">
                            <a asp-controller="Home" asp-action="About" class="text-white text-decoration-none opacity-75 text-hover-brand">About Us</a>
                            <a href="#" class="text-white text-decoration-none opacity-75 text-hover-brand">Contact Us</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <nav id="header-nav" class="navbar navbar-expand-lg border-bottom py-2">
            <div class="container align-items-center">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <img src="~/images/nextsteplogo.png" style="max-height: 55px; object-fit: contain;" alt="NextStep Logo">
                </a>

                <button class="navbar-toggler d-flex d-lg-none order-3 border-0 p-1 ms-2" type="button" data-bs-toggle="offcanvas"
                        data-bs-target="#bdNavbar" aria-controls="bdNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <i class="fa fa-bars fs-3"></i>
                </button>

                <div class="offcanvas offcanvas-end" tabindex="-1" id="bdNavbar">
                    <div class="offcanvas-header px-4 pb-0">
                        <a class="navbar-brand ps-3" asp-controller="Home" asp-action="Index">
                            <img src="~/images/nextsteplogo.png" style="max-height: 45px;" alt="logo">
                        </a>
                        <button type="button" class="btn-close btn-close-black p-5" data-bs-dismiss="offcanvas" aria-label="Close" data-bs-target="#bdNavbar"></button>
                    </div>
                    <div class="offcanvas-body align-items-center">

                        <ul id="navbar" class="navbar-nav fw-bold justify-content-center flex-grow-1">
                            <li class="nav-item"><a class="nav-link me-4 text-hover-brand" asp-controller="Home" asp-action="Index">Home</a></li>
                            <li class="nav-item"><a class="nav-link me-4 text-hover-brand" asp-controller="Products" asp-action="Index">Shop All</a></li>

                            <li class="nav-item dropdown">
                                <a class="nav-link me-4 dropdown-toggle border-0 text-hover-brand" href="#" id="categoriesDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">Categories</a>
                                <ul class="dropdown-menu fw-bold shadow border-0 rounded-3 mt-2" aria-labelledby="categoriesDropdown">
                                    @if (categories != null && categories.Any())
                                    {
                                        foreach (var cat in categories)
                                        {
                                            <li><a class="dropdown-item py-2 text-hover-brand" asp-controller="Search" asp-action="Index" asp-route-q="@cat.Name">@cat.Name</a></li>
                                        }
                                    }
                                    else
                                    {
                                        <li><span class="dropdown-item text-muted">No categories</span></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item py-2 text-hover-brand" asp-controller="Products" asp-action="Index">View All Shoes</a></li>
                                </ul>
                            </li>
                            <li class="nav-item"><a class="nav-link me-4 text-danger" asp-controller="Products" asp-action="Index" asp-route-onSale="true"><i class="fa fa-fire me-1"></i> Flash Sale</a></li>
                        </ul>

                        <div class="user-items ps-0 ps-md-5">
                            <ul class="d-flex justify-content-end list-unstyled align-items-center m-0 gap-3">

                                <li>
                                    <a href="#" class="search-item border-0 text-dark text-hover-brand" title="Search">
                                        <i class="fa fa-search fs-5"></i>
                                    </a>
                                </li>

                                <li class="dropdown">
                                    <a class="text-dark d-flex align-items-center text-decoration-none text-hover-brand dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        @if (SignInManager.IsSignedIn(User) && currentUser != null)
                                        {
                                            string pfp = string.IsNullOrEmpty(currentUser.ProfileImage) ? "/admin/img/undraw_profile.svg" : currentUser.ProfileImage;
                                            <img src="@pfp" class="rounded-circle border border-2 border-white shadow-sm" style="width: 32px; height: 32px; object-fit: cover;" alt="Profile Picture">
                                        }
                                        else
                                        {
                                            <i class="fa fa-user-circle fs-4"></i>
                                        }
                                    </a>

                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 mt-3" aria-labelledby="userDropdown">
                                        @if (SignInManager.IsSignedIn(User))
                                        {
                                            <li class="px-3 py-2 border-bottom mb-2 bg-light rounded-top">
                                                <span class="d-block fw-bold text-dark">@(currentUser?.FullName ?? "Athlete")</span>
                                                <small class="text-muted" style="font-size: 0.8rem;">@currentUser?.Email</small>
                                            </li>
                                            <li><a class="dropdown-item py-2 fw-semibold text-hover-brand" asp-controller="Orders" asp-action="Index"><i class="fa fa-box me-2 text-muted"></i> My Orders</a></li>
                                            <li><a class="dropdown-item py-2 fw-semibold text-hover-brand" asp-controller="Testimonials" asp-action="Create"><i class="fa fa-star text-warning me-2"></i> Rate Us</a></li>
                                            <li><a class="dropdown-item py-2 fw-semibold text-hover-brand" asp-area="Identity" asp-page="/Account/Manage/Index"><i class="fa fa-user-edit me-2 text-muted"></i> Edit Profile</a></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                                <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                                    <button type="submit" class="dropdown-item py-2 text-danger fw-bold"><i class="fa fa-sign-out-alt me-2"></i> Logout</button>
                                                </form>
                                            </li>
                                        }
                                        else
                                        {
                                            <li><a class="dropdown-item py-2 fw-semibold text-hover-brand" asp-area="Identity" asp-page="/Account/Login"><i class="fa fa-sign-in-alt me-2 text-muted"></i> Login</a></li>
                                            <li><a class="dropdown-item py-2 fw-semibold text-hover-brand" asp-area="Identity" asp-page="/Account/Register"><i class="fa fa-user-plus me-2 text-muted"></i> Create Account</a></li>
                                        }
                                    </ul>
                                </li>

                                <li>
                                    <a asp-controller="Wishlist" asp-action="Index" class="text-dark position-relative text-hover-brand" title="Wishlist">
                                        <i class="fa fa-heart fs-5"></i>
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.60rem;">0</span>
                                    </a>
                                </li>

                                <li>
                                    <a asp-controller="Cart" asp-action="Index" class="text-dark position-relative text-hover-brand" title="Shopping Cart">
                                        <i class="fa fa-shopping-cart fs-5"></i>
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.60rem;">0</span>
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-0">
        <main role="main" class="pb-3">
            <div class="container-fluid px-0">
                <main role="main" class="pb-3">

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="container mt-4 position-relative" style="z-index: 1000;">
                            <div class="alert alert-success alert-dismissible fade show shadow-sm text-center fw-bold rounded-pill" role="alert">
                                <i class="fa fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        </div>
                    }

                    @RenderBody()
                </main>
            </div>
            @RenderBody()
        </main>
    </div>

    <footer id="footer" class="bg-dark text-white py-5 mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <img src="~/images/nextsteplogo.png" style="max-height: 50px; filter: brightness(0) invert(1);" alt="NextStep Logo" class="mb-3">
                    <p class="text-muted">Step into greatness with premium sports gear designed for performance.</p>
                </div>
                <div class="col-md-4 mb-4 text-center">
                    <h5 class="fw-bold mb-3">Quick Links</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a asp-controller="Products" asp-action="Index" class="text-muted text-decoration-none text-hover-brand">Shop All</a></li>
                        <li class="mb-2"><a asp-controller="Products" asp-action="Index" asp-route-onSale="true" class="text-muted text-decoration-none text-hover-brand">Flash Sales</a></li>
                        <li class="mb-2"><a href="#" class="text-muted text-decoration-none text-hover-brand">Contact Support</a></li>
                    </ul>
                </div>
            </div>
            <div class="border-top border-secondary pt-3 mt-3 text-center text-muted small">
                <p class="mb-0">&copy; 2026 NextStep E-Commerce. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="~/user/js/jquery-1.11.0.min.js"></script>
    <script src="~/user/js/plugins.js"></script>
    <script src="~/user/js/script.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>