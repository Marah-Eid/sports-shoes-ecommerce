@model IEnumerable<SportsShoesEcommerce.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<h2 class="mb-4">Products</h2>

<form asp-controller="Products" asp-action="Search" method="get" class="mb-4 d-flex">
    <input type="text" name="searchText" value="@ViewBag.SearchText"
           class="form-control me-2" placeholder="Search products or categories..." />

    <button type="submit" class="btn btn-dark">Search</button>
</form>

<div class="row">
    @foreach (var product in Model)
    {
        var mainImage = product.ProductImages?.FirstOrDefault(x => x.IsMain)?.ImagePath
        ?? product.ProductImages?.FirstOrDefault()?.ImagePath
        ?? "/images/no-image.png";

        <div class="col-md-3 mb-4">
            <div class="card h-100">
                <img src="@mainImage" class="card-img-top" style="height:220px; object-fit:cover;" />

                <div class="card-body">
                    <h5>@product.Name</h5>

                    <p class="text-muted">
                        @product.Category?.Name
                    </p>

                    <p class="fw-bold">
                        $@product.Price
                    </p>

                    <a asp-controller="Products"
                       asp-action="Details"
                       asp-route-id="@product.Id"
                       class="btn btn-outline-dark w-100">
                        View Details
                    </a>
                </div>
            </div>
        </div>
    }
</div>