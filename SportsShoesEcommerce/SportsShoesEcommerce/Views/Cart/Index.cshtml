@model SportsShoesEcommerce.ViewModels.CartViewModel

@{
    ViewData["Title"] = "Cart";
}

<h2 class="mb-4">Shopping Cart</h2>

@if (Model.Items.Count == 0)
{
    <div class="alert alert-info">
        Your cart is empty.
    </div>

    <a asp-controller="Products" asp-action="Index" class="btn btn-dark">
        Continue Shopping
    </a>
}
else
{
    <table class="table table-bordered align-middle">
        <thead>
            <tr>
                <th>Image</th>
                <th>Product</th>
                <th>Size</th>
                <th>Color</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Total</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <img src="@item.ImagePath" width="80" height="80" style="object-fit:cover;" />
                    </td>

                    <td>@item.ProductName</td>
                    <td>@item.Size</td>
                    <td>@item.Color</td>
                    <td>$@item.Price</td>

                    <td>
                        <a asp-controller="Cart"
                           asp-action="Decrease"
                           asp-route-productVariantId="@item.ProductVariantId"
                           class="btn btn-sm btn-outline-secondary">
                            -
                        </a>

                        <span class="mx-2">@item.Quantity</span>

                        <a asp-controller="Cart"
                           asp-action="Increase"
                           asp-route-productVariantId="@item.ProductVariantId"
                           class="btn btn-sm btn-outline-secondary">
                            +
                        </a>
                    </td>

                    <td>$@item.Total</td>

                    <td>
                        <a asp-controller="Cart"
                           asp-action="Remove"
                           asp-route-productVariantId="@item.ProductVariantId"
                           class="btn btn-sm btn-danger">
                            Remove
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="text-end">
        <h4>Total: $@Model.TotalPrice</h4>

        <a asp-controller="Cart" asp-action="Clear" class="btn btn-outline-danger">
            Clear Cart
        </a>

        <a asp-controller="Checkout" asp-action="Index" class="btn btn-dark">
            Checkout
        </a>
    </div>
}