@{
    ViewData["Title"] = "Rate Us";
}

<style>
    .review-card {
        border-radius: 16px;
        background: #ffffff;
        box-shadow: 0 10px 25px rgba(0,0,0,0.03);
        border: 1px solid #f8f9fa;
    }

    /* Sleek, smaller stars */
    .star-rating {
        display: flex;
        flex-direction: row-reverse;
        justify-content: center;
        gap: 8px;
    }

        .star-rating input {
            display: none;
        }

        .star-rating label {
            font-size: 2.2rem;
            color: #e2e8f0;
            cursor: pointer;
            transition: all 0.2s ease;
        }

            .star-rating input:checked ~ label,
            .star-rating label:hover,
            .star-rating label:hover ~ label {
                color: #fbbf24;
                transform: scale(1.1);
            }

    /* Soft Grey Shadow Placeholder */
    textarea::placeholder {
        color: #a0aec0 !important;
        font-weight: 400;
        opacity: 0.8;
    }

    /* Focus state when typing */
    .form-control:focus {
        border-color: var(--brand-teal, #00C2CB) !important;
        box-shadow: 0 0 0 3px rgba(0, 194, 203, 0.1);
        background-color: #ffffff !important;
    }
</style>

<div class="container py-5 mt-5 mb-5" style="max-width: 450px;">

    <div class="review-card p-4 p-md-5 mx-auto">

        <div class="text-center mb-4 pt-2">
            <h4 class="fw-bold text-dark mb-1">Rate Your Experience</h4>
            <p class="text-muted small mb-0">We'd love to hear your thoughts.</p>
        </div>

        <div asp-validation-summary="ModelOnly" class="text-danger small text-center mb-3 fw-bold"></div>

        <form asp-controller="Testimonials" asp-action="Create" method="post">

            <div class="mb-4 text-center">
                <div class="star-rating">
                    <input type="radio" id="star5" name="rating" value="5" required />
                    <label for="star5" class="fa fa-star"></label>

                    <input type="radio" id="star4" name="rating" value="4" />
                    <label for="star4" class="fa fa-star"></label>

                    <input type="radio" id="star3" name="rating" value="3" />
                    <label for="star3" class="fa fa-star"></label>

                    <input type="radio" id="star2" name="rating" value="2" />
                    <label for="star2" class="fa fa-star"></label>

                    <input type="radio" id="star1" name="rating" value="1" />
                    <label for="star1" class="fa fa-star"></label>
                </div>
            </div>

            <div class="mb-4">
                <textarea class="form-control bg-light p-3" id="content" name="content" rows="3" placeholder="Tell us about your new gear..." required style="border-radius: 12px; resize: none; font-size: 0.95rem; border: 2px solid #e2e8f0;"></textarea>
            </div>

            <button type="submit" class="btn btn-dark w-100 rounded-pill fw-bold py-2 shadow-sm transition-hover">
                Submit
            </button>
        </form>
    </div>

    <div class="text-center mt-4">
        <a asp-controller="Home" asp-action="Index" class="text-muted small text-decoration-none text-hover-brand">
            <i class="fa fa-arrow-left me-1"></i> Back to Home
        </a>
    </div>
</div>