@model SportsShoesEcommerce.Models.Category

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Delete Category";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow mb-4 border-bottom-danger">
            <div class="card-header py-3 bg-danger">
                <h6 class="m-0 font-weight-bold text-white"><i class="fas fa-exclamation-triangle mr-2"></i> Confirm Delete</h6>
            </div>
            <div class="card-body text-center">
                <h4 class="text-gray-900 mb-4">Are you sure you want to delete this category?</h4>

                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <div class="mb-4">
                        <img src="~/images/categories/@Model.ImagePath" class="img-thumbnail shadow-sm" style="height: 150px; width: 150px; object-fit: cover;" />
                    </div>
                }

                <div class="p-3 bg-light rounded mb-4">
                    <h3 class="font-weight-bold text-dark">@Model.Name</h3>
                    <p class="text-muted">@Model.Description</p>
                </div>

                <p class="text-danger mb-4 small">
                    <i class="fas fa-info-circle mr-1"></i> Warning: Deleting this category might affect products linked to it.
                </p>

                <form asp-area="Admin" asp-controller="Categories" asp-action="Delete">
                    <input type="hidden" asp-for="Id" />

                    <button type="submit" class="btn btn-danger btn-lg px-5 shadow-sm">
                        <i class="fas fa-trash-alt mr-2"></i>Delete Permanently
                    </button>

                    <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="btn btn-secondary btn-lg px-5 shadow-sm">
                        Cancel
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>