@model IEnumerable<SportsShoesEcommerce.Models.Category>

@{
    ViewData["Title"] = "Categories Management";
    Layout = "_AdminLayout";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Categories</h1>
</div>

<div class="card shadow mb-4 border-left-primary">
    <div class="card-header py-3 d-flex justify-content-between align-items-center bg-light">
        <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-list mr-2"></i>All Categories</h6>

        @* إضافة asp-area="Admin" للزر الرئيسي *@
        <a asp-area="Admin" asp-controller="Categories" asp-action="Create" class="btn btn-primary btn-icon-split shadow-sm">
            <span class="icon text-white-50">
                <i class="fas fa-plus"></i>
            </span>
            <span class="text">Add New Category</span>
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-bordered" id="dataTable" width="100%" cellspacing="0">
                <thead class="thead-light">
                    <tr>
                        <th style="width: 70px;">Image</th>
                        <th>Category Name</th>
                        <th>Description</th>
                        <th style="width: 100px;">Status</th>
                        <th style="width: 150px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(item.ImagePath))
                                {
                                    <img src="~/images/categories/@item.ImagePath" width="45" height="45" class="rounded shadow-sm" style="object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="rounded bg-gray-200 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                                        <i class="fas fa-image text-gray-400"></i>
                                    </div>
                                }
                            </td>

                            <td class="font-weight-bold text-dark">@item.Name</td>

                            <td class="text-muted small">
                                @(item.Description?.Length > 50 ? item.Description.Substring(0, 50) + "..." : item.Description)
                            </td>

                            <td class="text-center">
                                @if (item.IsDeleted)
                                {
                                    <span class="badge badge-danger badge-pill px-3">Hidden</span>
                                }
                                else
                                {
                                    <span class="badge badge-success badge-pill px-3">Active</span>
                                }
                            </td>

                            <td class="text-center">
                                @* أزرار الأكشن مع إضافة asp-area و Details *@
                                <div class="btn-group" role="group">
                                    <a asp-area="Admin" asp-controller="Categories" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-info btn-sm shadow-sm" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-area="Admin" asp-controller="Categories" asp-action="Details" asp-route-id="@item.Id" class="btn btn-warning btn-sm shadow-sm" title="Details">
                                        <i class="fas fa-eye text-white"></i>
                                    </a>
                                    <a asp-area="Admin" asp-controller="Categories" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm shadow-sm" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#dataTable').DataTable();
        });
    </script>
}