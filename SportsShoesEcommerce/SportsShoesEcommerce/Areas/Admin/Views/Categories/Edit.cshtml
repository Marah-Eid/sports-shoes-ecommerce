@model SportsShoesEcommerce.Models.Category

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Category";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow mb-4 border-left-info">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-info"><i class="fas fa-edit mr-2"></i>Edit Category: @Model.Name</h6>
            </div>
            <div class="card-body">
                <form asp-area="Admin" asp-controller="Categories" asp-action="Edit" enctype="multipart/form-data" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    @* حقول مخفية للحفاظ على المعرف والمسار القديم للصورة *@
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ImagePath" />

                    <div class="row">
                        <div class="col-md-8">
                            <div class="form-group mb-3">
                                <label asp-for="Name" class="control-label font-weight-bold"></label>
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Description" class="control-label font-weight-bold"></label>
                                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="col-md-4 text-center">
                            <label class="control-label font-weight-bold">Current Image</label>
                            <div class="mb-2">
                                @if (!string.IsNullOrEmpty(Model.ImagePath))
                                {
                                    <img src="~/images/categories/@Model.ImagePath" class="img-thumbnail shadow-sm" style="width: 120px; height: 120px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-light rounded p-3">
                                        <i class="fas fa-image fa-3x text-gray-300"></i>
                                    </div>
                                }
                            </div>
                            <div class="custom-file mt-2">
                                <input type="file" name="imageFile" class="form-control-file" accept="image/*" />
                                <small class="text-muted d-block mt-1">Leave empty to keep current image</small>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div class="form-group form-check mb-4">
                        <label class="form-check-label py-2 px-3 bg-light rounded border w-100" style="cursor:pointer">
                            <input class="form-check-input mt-2" asp-for="IsDeleted" />
                            <span class="ml-4 font-weight-bold text-danger">Mark as Deleted</span>
                        </label>
                    </div>

                    <div class="form-group text-center">
                        <button type="submit" class="btn btn-info px-5 shadow-sm">
                            <i class="fas fa-save mr-1"></i> Save Changes
                        </button>
                        <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="btn btn-secondary px-5 shadow-sm">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}